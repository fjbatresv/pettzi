    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.56.0"
  },
  "workspaces": [
    "libs/api-pets",
    "libs/api-owners",
    "libs/api-events",
    "libs/api-catalogs",
    "libs/api-uploads",
    "libs/api-reminders",
