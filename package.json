    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.0.8",
    "@eslint/js": "^9.8.0",
    "@nx/angular": "^22.5.2",
    "@nx/esbuild": "22.5.2",
    "@nx/eslint": "22.5.2",
    "@nx/eslint-plugin": "22.5.2",
    "@nx/jest": "22.5.2",
    "@nx/js": "22.5.2",
    "@nx/node": "^22.5.2",
    "@nx/web": "22.5.2",
    "@schematics/angular": "^21.0.5",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "^1.15.11",
    "@swc/helpers": "~0.5.19",
    "@swc/jest": "~0.2.38",
    "@types/aws-lambda": "^8.10.138",
    "@types/jest": "^30.0.0",
    "@types/node": "25.3.0",
    "@typescript-eslint/utils": "^8.56.0",
    "angular-eslint": "^21.2.0",
    "aws-cdk-lib": "^2.239.0",
    "constructs": "^10.3.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "husky": "^9.1.6",
    "jest": "^30.0.2",
    "jest-environment-jsdom": "^30.0.2",
