{
  "name": "@peto/utils-dynamo",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./http": {
      "types": "./dist/http.d.ts",
      "import": "./dist/http.js",
      "default": "./dist/http.js"
    },
    "./key": {
      "types": "./dist/key.d.ts",
      "import": "./dist/key.js",
      "default": "./dist/key.js"
    }
  },
  "nx": {
    "targets": {
      "test": {
        "executor": "@nx/jest:jest",
        "outputs": [
          "{projectRoot}/test-output/jest/coverage"
        ],
        "options": {
          "jestConfig": "libs/utils-dynamo/jest.config.cts"
        }
      }
    }
  },
  "dependencies": {
    "tslib": "^2.3.0"
  }
}
