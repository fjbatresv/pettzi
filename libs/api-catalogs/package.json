{
  "name": "@pettzi/api-catalogs",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "nx": {
    "targets": {
      "test": {
        "executor": "@nx/jest:jest",
        "outputs": [
          "{projectRoot}/test-output/jest/coverage"
        ],
        "options": {
          "jestConfig": "libs/api-catalogs/jest.config.cts"
        }
      },
      "seed": {
        "executor": "nx:run-commands",
        "dependsOn": [
          "^build"
        ],
        "options": {
          "command": "ts-node --transpile-only libs/api-catalogs/src/seed/seed-catalogs.ts"
        }
      }
    }
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.694.0",
    "@aws-sdk/lib-dynamodb": "^3.991.0",
    "tslib": "^2.3.0",
    "@types/aws-lambda": "^8.10.138",
    "@pettzi/domain-model": "file:../domain-model",
    "@pettzi/utils-dynamo": "file:../utils-dynamo"
  }
}
